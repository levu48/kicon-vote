# Dev: authenticate against a LOCAL IdP (run the auth.kicon.com repo on :3000).
# The `vote` client's dev redirect (http://localhost:8084/auth/callback) is
# registered there. Discovery is fetched from this authority.
VITE_OIDC_AUTHORITY=http://localhost:3000

# The resource server (run the kicon-api repo on :3100).
VITE_API_BASE=http://localhost:3100
